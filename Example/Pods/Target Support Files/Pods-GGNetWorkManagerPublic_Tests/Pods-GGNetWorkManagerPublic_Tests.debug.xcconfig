CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/GGAFNetworking" "${PODS_CONFIGURATION_BUILD_DIR}/GGNetWorkManagerPublic" "${PODS_CONFIGURATION_BUILD_DIR}/GGYTKNetwork" "${PODS_CONFIGURATION_BUILD_DIR}/QMUIKit"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/GGAFNetworking/GGAFNetworking.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/GGNetWorkManagerPublic/GGNetWorkManagerPublic.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/GGYTKNetwork/GGYTKNetwork.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/QMUIKit/QMUIKit.framework/Headers"
OTHER_LDFLAGS = $(inherited) -framework "AVFoundation" -framework "CoreGraphics" -framework "CoreImage" -framework "CoreMedia" -framework "CoreServices" -framework "Foundation" -framework "GGAFNetworking" -framework "GGNetWorkManagerPublic" -framework "GGYTKNetwork" -framework "ImageIO" -framework "MobileCoreServices" -framework "Photos" -framework "PhotosUI" -framework "QMUIKit" -framework "QuartzCore" -framework "SystemConfiguration" -framework "UIKit"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
